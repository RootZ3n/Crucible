# Crucible local configuration example.
# Copy to .env for local use.
#
# WARNING: Never commit .env or real provider keys to git.
# .gitignore already excludes .env — do not override that.

# ── Provider keys ───────────────────────────────────────────────────

# ModelStudio / DashScope
DASHSCOPE_API_KEY=
MODELSTUDIO_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Ollama (local models - no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter
OPENROUTER_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# Z.ai
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# ── Service connections ─────────────────────────────────────────────

CRUCIBULUM_URL=http://localhost:18795
